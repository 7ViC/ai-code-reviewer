# ─── GCP Configuration ────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ─── Vertex AI ────────────────────────────────────────────────────────────────
VERTEX_MODEL=gemini-1.5-pro-001

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Fine-grained PAT with pull_requests: Read & Write, contents: Read
GITHUB_TOKEN=ghp_your_github_token_here

# A random secret string — must match what you set in the GitHub webhook settings
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret_here

# ─── Firestore ────────────────────────────────────────────────────────────────
FIRESTORE_COLLECTION=reviews
